{
  "project": {
    "name": "Orienteering Problem — Étude Comparative",
    "version": "1.0.0",
    "date": "2026-05-10",
    "description": "Comparaison de 3 méthodes exactes + 3 métaheuristiques pour le Orienteering Problem",
    "author": "Projet Optimisation Combinatoire"
  },

  "methods": {
    "exact": [
      {
        "name": "DP",
        "full_name": "Programmation Dynamique",
        "file": "op_exact_dp.py",
        "complexity": "O(2^n × n²)",
        "max_n": 22,
        "optimal": true,
        "description": "Bitmask DP garantissant optimalité pour petites instances"
      },
      {
        "name": "BB",
        "full_name": "Branch & Bound",
        "file": "op_exact_bb.py",
        "complexity": "O(n!)",
        "max_n": 40,
        "optimal": false,
        "description": "Énumération implicite avec borne supérieure greedy"
      },
      {
        "name": "ILP",
        "full_name": "Programmation Linéaire Entière",
        "file": "op_exact_ilp.py",
        "solver": "CBC (PuLP)",
        "max_n": 30,
        "optimal": true,
        "description": "Formulation MILP avec contraintes MTZ, résolveur CBC"
      }
    ],
    "heuristic": [
      {
        "name": "SA",
        "full_name": "Recuit Simulé",
        "file": "op_meta_sa.py",
        "type": "Métaheuristique stochastique",
        "parameters": {
          "alpha": 0.995,
          "T_min": 0.01,
          "iter_per_T": 100,
          "max_iter": 50000
        },
        "description": "Acceptation contrôlée de mouvements dégradants selon probabilité Boltzmann"
      },
      {
        "name": "Tabu",
        "full_name": "Recherche Tabou",
        "file": "op_meta_tabu.py",
        "type": "Métaheuristique déterministe",
        "parameters": {
          "tabu_tenure": 7,
          "n_neighbors": 30,
          "max_iter": 500,
          "no_improve_restart": 80
        },
        "description": "Liste tabou avec critère d'aspiration, intensification/diversification",
        "recommended": true
      },
      {
        "name": "GRASP",
        "full_name": "GRASP",
        "file": "op_meta_grasp.py",
        "type": "Métaheuristique itérative",
        "parameters": {
          "n_iter": 200,
          "alpha": 0.3
        },
        "description": "Boucle construction greedy randomisée (RCL) + amélioration locale"
      }
    ]
  },

  "execution": {
    "quick_test": {
      "command": "python main.py --test",
      "duration_seconds": 60,
      "description": "Vérification rapide que tous les modules fonctionnent"
    },
    "full_comparison": {
      "command": "python main.py --run-all",
      "duration_seconds": 600,
      "description": "Comparaison complète sur 6 tailles d'instances (8, 12, 16, 25, 40, 60)"
    },
    "dashboard": {
      "command": "python main.py",
      "file": "dashboard.html",
      "description": "Interface web interactive avec toutes les infos"
    }
  },

  "instances": {
    "small": {
      "range": "n ≤ 15",
      "recommended_methods": ["DP", "Tous"],
      "expected_gaps": "0%"
    },
    "medium": {
      "range": "15 < n ≤ 30",
      "recommended_methods": ["Tabu", "ILP", "B&B"],
      "expected_gaps": "0-5%"
    },
    "large": {
      "range": "n > 30",
      "recommended_methods": ["Tabu", "SA", "GRASP"],
      "expected_gaps": "5-15%"
    }
  },

  "parameters": {
    "generation": {
      "width": 100.0,
      "budget_ratio": 0.4,
      "score_range": [1, 10],
      "distance_metric": "Euclidean"
    },
    "time_limits": {
      "exact_small": 30,
      "exact_medium": 60,
      "heuristic": 10
    },
    "multi_seed": {
      "count": 5,
      "retention": "best"
    }
  },

  "output": {
    "metrics": [
      "score",
      "distance",
      "time",
      "gap",
      "optimal",
      "feasible"
    ],
    "formats": [
      "console_table",
      "html_dashboard",
      "json_export"
    ]
  },

  "files": {
    "core": [
      "op_utils.py",
      "op_exact_dp.py",
      "op_exact_bb.py",
      "op_exact_ilp.py",
      "op_meta_sa.py",
      "op_meta_tabu.py",
      "op_meta_grasp.py"
    ],
    "execution": [
      "main.py",
      "op_run_all.py",
      "test_all_methods.py"
    ],
    "web": [
      "dashboard.html"
    ],
    "documentation": [
      "INDEX.md",
      "START.md",
      "UTILISATION.md",
      "README.md",
      "SYNTHÈSE_TECHNIQUE.md",
      "MANIFEST.txt"
    ],
    "config": [
      "requirements.txt",
      "config.json"
    ]
  },

  "dependencies": {
    "required": [
      {
        "name": "numpy",
        "version": "any",
        "source": "standard",
        "description": "Calculs matriciels"
      }
    ],
    "optional": [
      {
        "name": "pulp",
        "version": ">= 2.0",
        "source": "pip",
        "auto_install": true,
        "description": "Solveur ILP (CBC inclus)"
      }
    ],
    "standard_library": [
      "random",
      "time",
      "math",
      "dataclasses",
      "collections",
      "json",
      "subprocess",
      "webbrowser"
    ]
  },

  "quality": {
    "code_lines": 1500,
    "documentation_lines": 3000,
    "all_files_tested": true,
    "all_files_executable": true,
    "no_external_setup": true
  },

  "recommendations": {
    "n_le_15": {
      "method": "DP",
      "reason": "Optimal garanti, ultra-rapide",
      "time_expected": "< 0.01s"
    },
    "n_15_30": {
      "method": "Tabu",
      "reason": "Meilleur rapport qualité/temps",
      "alternative": "ILP ou B&B pour optimalité",
      "time_expected": "0.1-1.0s"
    },
    "n_gt_30": {
      "method": "Tabu",
      "reason": "Seule viable en pratique",
      "time_expected": "1-3s"
    }
  },

  "contact": {
    "project": "Orienteering Problem — Étude Comparative",
    "year": 2026,
    "status": "Production Ready"
  }
}
